</div>
<script>
(function(){
  const filters = {ptype:'all', pb:'all'};
  const buttons = document.querySelectorAll('.filters button');
  const rows = document.querySelectorAll('#cmp-body tr');
  function applyFilters(){
    rows.forEach(r => {
      const ok = (filters.ptype==='all' || r.dataset.ptype===filters.ptype) &&
                 (filters.pb==='all' || r.dataset.pb===filters.pb);
      r.classList.toggle('hidden', !ok);
    });
    // disable buttons that would yield 0
    buttons.forEach(btn => {
      const k = btn.dataset.filter, v = btn.dataset.val;
      if (v === 'all') return;
      let cnt = 0;
      rows.forEach(r => {
        const okOther = Object.keys(filters).every(fk => fk===k ? true : (filters[fk]==='all' || r.dataset[fk]===filters[fk]));
        if (okOther && r.dataset[k]===v) cnt++;
      });
      btn.disabled = cnt===0;
    });
  }
  buttons.forEach(btn => {
    btn.addEventListener('click', () => {
      if (btn.disabled) return;
      const k = btn.dataset.filter, v = btn.dataset.val;
      filters[k] = v;
      buttons.forEach(b => { if (b.dataset.filter===k) b.classList.toggle('active', b.dataset.val===v); });
      applyFilters();
    });
  });
  applyFilters();
})();
</script>
</section>
